---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Not found — TRT Clinic Finder">
  <section class="container-prose pt-24 pb-24 max-w-xl text-center">
    <p class="text-sm font-semibold tracking-wider text-brand-700 uppercase">404</p>
    <h1 class="mt-2 font-display text-4xl md:text-5xl font-semibold text-ink-900">Page not found</h1>
    <p class="mt-4 text-ink-600">That clinic or state isn't in our directory — yet.</p>
    <div class="mt-8 flex justify-center gap-3">
      <a href="/" class="inline-flex items-center rounded-lg bg-brand-600 px-5 py-3 text-white font-semibold hover:bg-brand-700">Go home</a>
      <a href="/clinics/" class="inline-flex items-center rounded-lg bg-white px-5 py-3 text-ink-800 font-semibold ring-1 ring-ink-200 hover:ring-ink-300">Browse clinics</a>
    </div>
  </section>
</BaseLayout>
