---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Telehealth TRT clinics - coming soon | TRT Index">
  <section class="container-prose pt-20 pb-24 max-w-2xl">
    <p class="text-sm font-semibold tracking-wider text-brand-700 uppercase">Coming soon</p>
    <h1 class="mt-2 font-display text-4xl md:text-5xl font-semibold text-ink-900">
      Telehealth TRT providers
    </h1>
    <p class="mt-4 text-lg text-ink-600">
      We're building a separate section for online-only TRT and HRT clinics - the ones that ship labs to your door and prescribe across multiple states. Until then, browse the state directory for in-person options.
    </p>
    <div class="mt-8">
      <a href="/clinics/" class="inline-flex items-center rounded-lg bg-brand-600 px-5 py-3 text-white font-semibold hover:bg-brand-700">
        Browse by state instead →
      </a>
    </div>
  </section>
</BaseLayout>
