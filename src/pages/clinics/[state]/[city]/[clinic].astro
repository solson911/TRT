---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import ClinicCard from '../../../../components/ClinicCard.astro';
import ClinicPhotos from '../../../../components/ClinicPhotos.astro';
import ClinicReviews from '../../../../components/ClinicReviews.astro';
import Icon from '../../../../components/Icon.astro';
import { STATE_BY_SLUG } from '../../../../data/states.js';
import { loadClinics, clinicsByCity, primaryChain, isBiote, isPermanentlyClosed, isTemporarilyClosed, amenities, loadWriteup, isHoneytoken } from '../../../../data/clinics.js';
import { clinicCrumbs, breadcrumbJsonLd } from '../../../../data/breadcrumbs.js';

export function getStaticPaths() {
  return loadClinics()
    .filter((c) => !c.telehealth && c.stateSlug && c.citySlug && c.slug)
    .map((c) => ({
      params: { state: c.stateSlug, city: c.citySlug, clinic: c.slug },
      props: { clinic: c },
    }));
}

const { state } = Astro.params;
const { clinic } = Astro.props;
const stateInfo = STATE_BY_SLUG[state];

const chain = primaryChain(clinic);
const biote = isBiote(clinic);
const closed = isPermanentlyClosed(clinic);
const tempClosed = isTemporarilyClosed(clinic);
const honeytoken = isHoneytoken(clinic);
const amenityList = amenities(clinic);
const writeup = loadWriteup(clinic.placeId);

const SERVICE_EXPLAIN = {
  TRT: 'Testosterone replacement therapy - injections, creams, or pellets for clinically low testosterone.',
  HRT: 'Hormone replacement therapy - broader endocrine care beyond just testosterone.',
  BHRT: 'Bioidentical hormone replacement therapy - compounded hormones chemically identical to the body\'s own.',
  Peptides: 'Short-chain amino acid therapies (sermorelin, BPC-157, etc.) for recovery, sleep, or growth-hormone support.',
  'GLP-1': 'Semaglutide/tirzepatide-class medications for weight management, often offered alongside TRT.',
  Wellness: 'General men\'s health, IV therapy, nutrition, or anti-aging add-ons beyond hormones alone.',
  Pellets: 'Long-release testosterone pellets implanted under the skin every 3-6 months.',
};
const SERVICE_COLORS = {
  TRT:     'bg-brand-50 text-brand-700 ring-brand-200',
  HRT:     'bg-violet-50 text-violet-700 ring-violet-200',
  BHRT:    'bg-violet-50 text-violet-700 ring-violet-200',
  Peptides:'bg-amber-50 text-amber-800 ring-amber-200',
  'GLP-1': 'bg-teal-50 text-teal-700 ring-teal-200',
  Wellness:'bg-ink-100 text-ink-700 ring-ink-200',
  Pellets: 'bg-rose-50 text-rose-700 ring-rose-200',
};
// Merge site-declared services with our tag-based services so the block is
// richer on clinics whose site mentions a tag we didn't tag at Places-classify
// time.
const siteServices = Array.isArray(writeup?.services) ? writeup.services : [];
const mergedServices = Array.from(new Set([...(clinic.services || []), ...siteServices])).filter((s) => SERVICE_EXPLAIN[s]);

// "Other clinics in {city}", excluding current. For closed clinics, surface more
// (6) and promote visually; for live clinics, keep it tight (4).
const siblings = (clinicsByCity(clinic.stateSlug)[clinic.citySlug] || [])
  .filter((c) => c.slug !== clinic.slug)
  .sort((a, b) => {
    const score = (c) => (c.rating || 0) * Math.log10(1 + (c.ratingCount || 0));
    return score(b) - score(a);
  })
  .slice(0, closed ? 6 : 4);

const mapQuery = clinic.lat && clinic.lng
  ? `${clinic.lat},${clinic.lng}`
  : encodeURIComponent([clinic.name, clinic.address].filter(Boolean).join(' '));
const mapEmbed = `https://www.google.com/maps?q=${mapQuery}&z=15&output=embed`;
const directionsUrl = clinic.lat && clinic.lng
  ? `https://www.google.com/maps/dir/?api=1&destination=${clinic.lat},${clinic.lng}`
  : `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent([clinic.name, clinic.address].filter(Boolean).join(' '))}`;

// LocalBusiness / MedicalBusiness structured data. Skipped on closed clinics
// (we don't want rich snippets promoting a business that no longer exists).
// The Places photo API key is public by design - restricted by HTTP Referer
// in Cloud Console.
const PHOTO_KEY = 'AIzaSyCIrnX_thibzANXFSbkyu04cFWoWMjK718';
const heroImage = clinic.photos && clinic.photos[0]
  ? `https://places.googleapis.com/v1/${clinic.photos[0].name}/media?maxWidthPx=1200&key=${PHOTO_KEY}`
  : undefined;

const breadcrumbLd = breadcrumbJsonLd(clinicCrumbs(clinic, stateInfo?.name || clinic.state));

const businessLd = closed ? null : {
  '@context': 'https://schema.org',
  '@type': 'MedicalBusiness',
  name: clinic.name,
  url: `https://trtindex.com/clinics/${clinic.stateSlug}/${clinic.citySlug}/${clinic.slug}/`,
  ...(clinic.website && { sameAs: [clinic.website] }),
  ...(heroImage && { image: heroImage }),
  ...(clinic.phone && { telephone: clinic.phone }),
  ...(clinic.address && {
    address: {
      '@type': 'PostalAddress',
      streetAddress: clinic.street || undefined,
      addressLocality: clinic.city || undefined,
      addressRegion: clinic.state || undefined,
      postalCode: clinic.zip || undefined,
      addressCountry: 'US',
    },
  }),
  ...(clinic.lat && clinic.lng && {
    geo: { '@type': 'GeoCoordinates', latitude: clinic.lat, longitude: clinic.lng },
  }),
  ...(clinic.rating && clinic.ratingCount && {
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: clinic.rating,
      reviewCount: clinic.ratingCount,
    },
  }),
  ...(clinic.reviews && clinic.reviews.length > 0 && {
    review: clinic.reviews.slice(0, 5).map((r) => ({
      '@type': 'Review',
      author: { '@type': 'Person', name: r.authorName || 'Google reviewer' },
      ...(r.rating && {
        reviewRating: { '@type': 'Rating', ratingValue: r.rating, bestRating: 5 },
      }),
      ...(r.publishTime && { datePublished: r.publishTime }),
      ...(r.text && { reviewBody: r.text }),
    })),
  }),
};

const jsonLd = businessLd ? [businessLd, breadcrumbLd] : [breadcrumbLd];
---
<BaseLayout
  title={closed
    ? `${clinic.name} - Permanently Closed | TRT Index`
    : `${clinic.name} - ${clinic.city}, ${stateInfo?.abbr} | TRT Index`}
  noindex={closed || honeytoken}
  jsonLd={honeytoken ? [] : jsonLd}
>
  {closed && (
    <section class="bg-amber-50 border-y border-amber-200">
      <div class="container-prose py-4 flex items-start gap-3">
        <Icon name="info" size={20} class="text-amber-700 mt-0.5 shrink-0" />
        <div>
          <div class="font-semibold text-amber-900">This clinic has permanently closed</div>
          <p class="text-sm text-amber-800 mt-0.5">The information below is preserved for reference. See alternative TRT clinics in {clinic.city} further down, or <a href={`/clinics/${clinic.stateSlug}/${clinic.citySlug}/`} class="underline font-medium">browse all clinics in {clinic.city}</a>.</p>
        </div>
      </div>
    </section>
  )}
  {honeytoken && (
    <section class="bg-rose-50 border-y border-rose-200">
      <div class="container-prose py-4 flex items-start gap-3">
        <Icon name="info" size={20} class="text-rose-700 mt-0.5 shrink-0" />
        <div>
          <div class="font-semibold text-rose-900">This is a sentinel listing</div>
          <p class="text-sm text-rose-800 mt-0.5">This is not a real clinic. It's a watermark we publish to detect unauthorized scraping and republication of TRT Index data. If you found your way here from another site, that site is republishing our data without permission. Browse <a href={`/clinics/${clinic.stateSlug}/${clinic.citySlug}/`} class="underline font-medium">real clinics in {clinic.city}</a>.</p>
          <p class="mt-1 text-xs text-rose-700/80 font-mono">{clinic.watermark}</p>
        </div>
      </div>
    </section>
  )}
  <section class="container-prose pt-14 pb-6">
    <nav class="text-sm text-ink-500 mb-3">
      <a href="/" class="hover:text-ink-900">Home</a>
      <span class="mx-1.5">/</span>
      <a href="/clinics/" class="hover:text-ink-900">States</a>
      <span class="mx-1.5">/</span>
      <a href={`/clinics/${clinic.stateSlug}/`} class="hover:text-ink-900">{stateInfo?.name}</a>
      <span class="mx-1.5">/</span>
      <a href={`/clinics/${clinic.stateSlug}/${clinic.citySlug}/`} class="hover:text-ink-900">{clinic.city}</a>
      <span class="mx-1.5">/</span>
      <span class="text-ink-900">{clinic.name}</span>
    </nav>

    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6">
      <div class="min-w-0">
        <div class="flex flex-wrap gap-1.5 mb-2">
          {closed && (
            <span class="inline-flex items-center rounded-md bg-ink-900 px-2 py-0.5 text-xs font-semibold text-white">Permanently Closed</span>
          )}
          {tempClosed && (
            <span class="inline-flex items-center rounded-md bg-amber-100 px-2 py-0.5 text-xs font-semibold text-amber-900 ring-1 ring-inset ring-amber-300">Temporarily Closed</span>
          )}
          {chain && (
            <span class="inline-flex items-center rounded-md bg-ink-100 px-2 py-0.5 text-xs font-semibold text-ink-700">{chain}</span>
          )}
          {biote && !chain?.toLowerCase().includes('biote') && (
            <span class="inline-flex items-center rounded-md bg-amber-50 px-2 py-0.5 text-xs font-semibold text-amber-800 ring-1 ring-inset ring-amber-200">Biote Certified</span>
          )}
        </div>
        <h1 class="font-display text-3xl md:text-4xl font-semibold text-ink-900 leading-tight">{clinic.name}</h1>
        {clinic.primaryTypeDisplay && (
          <p class="mt-1 text-sm font-medium text-ink-500">{clinic.primaryTypeDisplay}</p>
        )}
        {clinic.address && <p class="mt-2 text-ink-600">{clinic.address}</p>}
        {clinic.rating && (
          <div class="mt-3 inline-flex items-center gap-2 rounded-full bg-amber-50 px-3 py-1 ring-1 ring-inset ring-amber-200">
            <Icon name="star" size={14} stroke={0} class="fill-amber-500 text-amber-500" />
            <span class="text-sm font-semibold text-ink-900">{clinic.rating.toFixed(1)}</span>
            <span class="text-sm text-ink-600">· {(clinic.ratingCount ?? 0).toLocaleString()} reviews</span>
          </div>
        )}
      </div>
      {!closed && (
        <div class="flex flex-wrap gap-2">
          {clinic.phone && (
            <a href={`tel:${clinic.phone.replace(/[^0-9+]/g, '')}`} class="inline-flex items-center gap-2 rounded-lg bg-brand-600 px-4 py-2 text-white text-sm font-semibold hover:bg-brand-700">
              <Icon name="phone" size={16} /> Call {clinic.phone}
            </a>
          )}
          {clinic.website && (
            <a href={clinic.website} target="_blank" rel="nofollow noopener noreferrer external" class="inline-flex items-center gap-2 rounded-lg bg-white px-4 py-2 text-ink-800 text-sm font-semibold ring-1 ring-ink-200 hover:ring-ink-300">
              <Icon name="globe" size={16} /> Website
            </a>
          )}
          <a href={directionsUrl} target="_blank" rel="nofollow noopener noreferrer external" class="inline-flex items-center gap-2 rounded-lg bg-white px-4 py-2 text-ink-800 text-sm font-semibold ring-1 ring-ink-200 hover:ring-ink-300">
            <Icon name="compass" size={16} /> Directions
          </a>
        </div>
      )}
      {closed && (
        <a href={`/clinics/${clinic.stateSlug}/${clinic.citySlug}/`} class="inline-flex items-center gap-2 rounded-lg bg-brand-600 px-4 py-2 text-white text-sm font-semibold hover:bg-brand-700 self-start">
          <Icon name="search" size={16} /> See open clinics in {clinic.city}
        </a>
      )}
    </div>
  </section>

  {clinic.photos && clinic.photos.length > 0 && (
    <ClinicPhotos photos={clinic.photos} clinicName={clinic.name} googleUrl={clinic.googleUrl} />
  )}

  {(writeup || mergedServices.length > 0) && !closed && (
    <section class="container-prose pb-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {writeup && (
          <div class="lg:col-span-2 rounded-2xl bg-white ring-1 ring-ink-100 p-6">
            <h2 class="font-display text-xl font-semibold text-ink-900">About this clinic</h2>
            <p class="mt-3 text-ink-700 leading-relaxed">{writeup.overview}</p>
            {Array.isArray(writeup.highlights) && writeup.highlights.length > 0 && (
              <ul class="mt-4 space-y-2">
                {writeup.highlights.map((h) => (
                  <li class="flex items-start gap-2 text-sm text-ink-700">
                    <Icon name="check" size={16} class="text-brand-600 mt-0.5 shrink-0" />
                    <span>{h}</span>
                  </li>
                ))}
              </ul>
            )}
            {writeup.targetAudience && (
              <p class="mt-4 text-sm text-ink-600 border-t border-ink-100 pt-3">
                <span class="font-semibold text-ink-800">Fits:</span> {writeup.targetAudience}
              </p>
            )}
            <p class="mt-4 text-[11px] text-ink-400">
              Summary drafted from the clinic's public website. Verify specifics directly before booking.
            </p>
          </div>
        )}
        {mergedServices.length > 0 && (
          <div class={`${writeup ? '' : 'lg:col-span-3'} rounded-2xl bg-white ring-1 ring-ink-100 p-6`}>
            <h2 class="font-display text-xl font-semibold text-ink-900">Services offered</h2>
            <div class="mt-3 flex flex-wrap gap-1.5">
              {mergedServices.map((s) => (
                <span class={`inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium ring-1 ring-inset ${SERVICE_COLORS[s] || 'bg-ink-100 text-ink-700 ring-ink-200'}`}>{s}</span>
              ))}
            </div>
            <dl class="mt-4 space-y-3">
              {mergedServices.map((s) => (
                <div>
                  <dt class="text-sm font-semibold text-ink-900">{s}</dt>
                  <dd class="text-sm text-ink-600">{SERVICE_EXPLAIN[s]}</dd>
                </div>
              ))}
            </dl>
          </div>
        )}
      </div>
    </section>
  )}

  <section class="container-prose pb-8 grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2">
      <div class="overflow-hidden rounded-2xl ring-1 ring-ink-100 bg-white">
        <iframe
          src={mapEmbed}
          title={`Map showing ${clinic.name}`}
          class="w-full h-[340px] md:h-[420px]"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        ></iframe>
      </div>
    </div>
    <aside class="space-y-4">
      {clinic.services && clinic.services.length > 0 && (
        <div class="rounded-2xl ring-1 ring-ink-100 bg-white p-5">
          <h2 class="text-xs font-semibold tracking-wider text-ink-500 uppercase mb-2">Services</h2>
          <div class="flex flex-wrap gap-1.5">
            {clinic.services.map((s) => (
              <span class="inline-flex items-center rounded-full bg-brand-50 px-2.5 py-0.5 text-xs font-medium text-brand-700 ring-1 ring-inset ring-brand-200">{s}</span>
            ))}
          </div>
        </div>
      )}
      {amenityList.length > 0 && (
        <div class="rounded-2xl ring-1 ring-ink-100 bg-white p-5">
          <h2 class="text-xs font-semibold tracking-wider text-ink-500 uppercase mb-2">Amenities</h2>
          <ul class="space-y-1.5 text-sm text-ink-700">
            {amenityList.map((a) => (
              <li class="flex items-center gap-2">
                <Icon name={a.icon} size={16} class="text-ink-500 shrink-0" />
                <span>{a.label}</span>
              </li>
            ))}
          </ul>
        </div>
      )}
      {clinic.hours && clinic.hours.length > 0 && (
        <div class="rounded-2xl ring-1 ring-ink-100 bg-white p-5">
          <h2 class="text-xs font-semibold tracking-wider text-ink-500 uppercase mb-2">Hours</h2>
          <ul class="text-sm text-ink-700 space-y-1">
            {clinic.hours.map((h) => <li>{h}</li>)}
          </ul>
        </div>
      )}
      <div class="rounded-2xl ring-1 ring-ink-100 bg-white p-5 text-sm text-ink-600 space-y-2">
        {clinic.phone && (
          <div class="flex items-start gap-2"><span class="text-ink-400 shrink-0">Phone</span><a href={`tel:${clinic.phone.replace(/[^0-9+]/g, '')}`} class="text-ink-800 hover:text-brand-700">{clinic.phone}</a></div>
        )}
        {clinic.website && (
          <div class="flex items-start gap-2"><span class="text-ink-400 shrink-0">Web</span><a href={clinic.website} target="_blank" rel="nofollow noopener noreferrer external" class="truncate text-ink-800 hover:text-brand-700">{clinic.website.replace(/^https?:\/\//, '').replace(/\/$/, '')}</a></div>
        )}
        {clinic.googleUrl && (
          <div class="flex items-start gap-2"><span class="text-ink-400 shrink-0">Google</span><a href={clinic.googleUrl} target="_blank" rel="nofollow noopener noreferrer external" class="text-ink-800 hover:text-brand-700">View listing</a></div>
        )}
      </div>
    </aside>
  </section>

  {clinic.reviews && clinic.reviews.length > 0 && (
    <ClinicReviews
      reviews={clinic.reviews}
      googleUrl={clinic.googleUrl}
      rating={clinic.rating}
      ratingCount={clinic.ratingCount}
    />
  )}

  {siblings.length > 0 && (
    <section class="container-prose pb-16">
      <div class="flex items-end justify-between mb-4">
        <h2 class="font-display text-xl md:text-2xl font-semibold text-ink-900">
          {closed ? `Open TRT clinics in ${clinic.city}` : `Other clinics in ${clinic.city}`}
        </h2>
        <a href={`/clinics/${clinic.stateSlug}/${clinic.citySlug}/`} class="text-sm font-medium text-brand-700 hover:text-brand-800">See all →</a>
      </div>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {siblings.map((c) => (
          <li><ClinicCard clinic={c} /></li>
        ))}
      </ul>
    </section>
  )}

  <section class="container-prose pb-24 text-xs text-ink-500">
    Data compiled from public sources. Last updated: {clinic.lastSeenAt ? new Date(clinic.lastSeenAt).toLocaleDateString() : 'n/a'}.
  </section>
</BaseLayout>
