---
import Icon from './Icon.astro';
import { primaryChain, isBiote, amenities } from '../data/clinics.js';

interface Clinic {
  slug: string;
  name: string;
  address?: string;
  city?: string;
  state?: string;
  zip?: string;
  phone?: string;
  website?: string;
  rating?: number;
  ratingCount?: number;
  priceLevel?: string;
  services?: string[];
  chain?: string;
  biote?: boolean;
  verified?: boolean;
  stateSlug: string;
  citySlug: string;
}

interface Props {
  clinic: Clinic;
}

const { clinic } = Astro.props;
const chain = primaryChain(clinic);
const biote = isBiote(clinic);
const amenityList = amenities(clinic);
const typeLabel = clinic.primaryTypeDisplay;

const SERVICE_STYLE = {
  TRT:      'bg-brand-50 text-brand-700 ring-brand-200',
  HRT:      'bg-violet-50 text-violet-700 ring-violet-200',
  BHRT:     'bg-violet-50 text-violet-700 ring-violet-200',
  Peptides: 'bg-amber-50 text-amber-800 ring-amber-200',
  'GLP-1':  'bg-teal-50 text-teal-700 ring-teal-200',
  Wellness: 'bg-ink-100 text-ink-700 ring-ink-200',
};
const defaultService = 'bg-ink-100 text-ink-700 ring-ink-200';

// Build star segments (filled / half / empty) for a visual rating row.
const rating = typeof clinic.rating === 'number' ? clinic.rating : null;
function starStates(r) {
  const out = [];
  for (let i = 1; i <= 5; i++) {
    if (r >= i) out.push('full');
    else if (r >= i - 0.5) out.push('half');
    else out.push('empty');
  }
  return out;
}
const stars = rating !== null ? starStates(rating) : null;

const faviconPath = `/img/clinics/${clinic.placeId}.png`;

// Two-letter fallback monogram if favicon missing
const monogram = (clinic.name || '?')
  .replace(/[^A-Za-z\s]/g, '')
  .split(/\s+/)
  .filter(Boolean)
  .slice(0, 2)
  .map((w) => w[0].toUpperCase())
  .join('') || '?';
---
<a
  href={`/clinics/${clinic.stateSlug}/${clinic.citySlug}/${clinic.slug}/`}
  class="card-lift group block rounded-2xl border border-ink-100 bg-white p-5 h-full"
>
  <div class="flex items-start gap-4">
    <div class="shrink-0 relative h-12 w-12 rounded-xl bg-ink-50 ring-1 ring-ink-100 overflow-hidden grid place-items-center">
      <span class="absolute inset-0 grid place-items-center font-display text-sm font-semibold text-ink-500">{monogram}</span>
      <img
        src={faviconPath}
        alt=""
        width="40"
        height="40"
        loading="lazy"
        decoding="async"
        class="relative h-10 w-10 object-contain"
        onerror="this.style.display='none'"
      />
    </div>
    <div class="min-w-0 flex-1">
      <div class="flex items-start justify-between gap-3">
        <div class="min-w-0">
          <h3 class="font-display text-lg font-semibold leading-tight text-ink-900 group-hover:text-brand-700">
            {clinic.name}
          </h3>
          {(chain || biote || clinic.verified) && (
            <div class="mt-1.5 flex flex-wrap gap-1.5">
              {chain && (
                <span class="inline-flex items-center rounded-md bg-ink-100 px-2 py-0.5 text-[11px] font-semibold text-ink-700">
                  {chain}
                </span>
              )}
              {biote && !chain?.toLowerCase().includes('biote') && (
                <span class="inline-flex items-center gap-1 rounded-md bg-amber-50 px-2 py-0.5 text-[11px] font-semibold text-amber-800 ring-1 ring-inset ring-amber-200">
                  <Icon name="shield-check" size={12} stroke={2.5} /> Biote Certified
                </span>
              )}
            </div>
          )}
        </div>
        {rating !== null && (
          <div class="shrink-0 text-right">
            <div class="inline-flex items-center gap-0.5">
              {stars.map((state) => (
                <span class={state === 'full' ? 'text-amber-500' : state === 'half' ? 'text-amber-500/60' : 'text-ink-200'}>
                  <Icon name="star" size={13} stroke={0} class="fill-current" />
                </span>
              ))}
            </div>
            <div class="mt-0.5 text-xs text-ink-500">
              <span class="font-semibold text-ink-800">{rating.toFixed(1)}</span>
              {' · '}{clinic.ratingCount ?? 0} reviews
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
  {clinic.address && (
    <p class="mt-3 flex items-start gap-1.5 text-sm text-ink-600">
      <Icon name="map-pin" size={14} class="mt-0.5 shrink-0 text-ink-400" />
      <span>
        {typeLabel && <span class="text-ink-500">{typeLabel} · </span>}
        {clinic.address}
      </span>
    </p>
  )}
  {clinic.services && clinic.services.length > 0 && (
    <div class="mt-3 flex flex-wrap gap-1.5">
      {clinic.services.slice(0, 4).map((s) => (
        <span class={`inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium ring-1 ring-inset ${SERVICE_STYLE[s] || defaultService}`}>
          {s}
        </span>
      ))}
    </div>
  )}
  <div class="mt-4 flex items-center gap-4 text-xs text-ink-500">
    {clinic.phone && (
      <span class="inline-flex items-center gap-1">
        <Icon name="phone" size={12} class="text-ink-400" />
        {clinic.phone}
      </span>
    )}
    {clinic.website && (
      <span class="inline-flex items-center gap-1 truncate max-w-[180px]">
        <Icon name="globe" size={12} class="text-ink-400 shrink-0" />
        <span class="truncate">{clinic.website.replace(/^https?:\/\//, '').replace(/\/$/, '')}</span>
      </span>
    )}
    {amenityList.length > 0 && (
      <span class="ml-auto inline-flex items-center gap-2 text-ink-400">
        {amenityList.map((a) => (
          <span title={a.label} aria-label={a.label} class="inline-flex">
            <Icon name={a.icon} size={14} />
          </span>
        ))}
      </span>
    )}
  </div>
</a>
