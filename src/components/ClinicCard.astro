---
import Icon from './Icon.astro';
import { primaryChain, isBiote } from '../data/clinics.js';

interface Clinic {
  slug: string;
  name: string;
  address?: string;
  city?: string;
  state?: string;
  zip?: string;
  phone?: string;
  website?: string;
  rating?: number;
  ratingCount?: number;
  priceLevel?: string;
  services?: string[];
  chain?: string;
  biote?: boolean;
  verified?: boolean;
  stateSlug: string;
  citySlug: string;
}

interface Props {
  clinic: Clinic;
}

const { clinic } = Astro.props;
const chain = primaryChain(clinic);
const biote = isBiote(clinic);
---
<a
  href={`/clinics/${clinic.stateSlug}/${clinic.citySlug}/${clinic.slug}/`}
  class="card-lift group block rounded-2xl border border-ink-100 bg-white p-5 h-full"
>
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0">
      <h3 class="font-display text-lg font-semibold leading-tight text-ink-900 group-hover:text-brand-700">
        {clinic.name}
      </h3>
      {(chain || biote || clinic.verified) && (
        <div class="mt-1.5 flex flex-wrap gap-1.5">
          {chain && (
            <span class="inline-flex items-center rounded-md bg-ink-100 px-2 py-0.5 text-[11px] font-semibold text-ink-700">
              {chain}
            </span>
          )}
          {biote && !chain?.toLowerCase().includes('biote') && (
            <span class="inline-flex items-center gap-1 rounded-md bg-amber-50 px-2 py-0.5 text-[11px] font-semibold text-amber-800 ring-1 ring-inset ring-amber-200">
              <Icon name="shield-check" size={12} stroke={2.5} /> Biote Certified
            </span>
          )}
          {clinic.verified && (
            <span class="inline-flex items-center gap-1 rounded-md bg-brand-600 px-2 py-0.5 text-[11px] font-semibold text-white">
              <Icon name="check" size={12} stroke={3} /> Verified
            </span>
          )}
        </div>
      )}
    </div>
    {clinic.rating && (
      <div class="shrink-0 text-right">
        <div class="inline-flex items-center gap-1 text-amber-500">
          <Icon name="star" size={14} stroke={0} class="fill-current" />
          <span class="text-sm font-semibold leading-none text-ink-900">{clinic.rating.toFixed(1)}</span>
        </div>
        <div class="text-xs text-ink-500 mt-0.5">{clinic.ratingCount ?? 0} reviews</div>
      </div>
    )}
  </div>
  {clinic.address && (
    <p class="mt-2 flex items-start gap-1.5 text-sm text-ink-600">
      <Icon name="map-pin" size={14} class="mt-0.5 shrink-0 text-ink-400" />
      <span>{clinic.address}</span>
    </p>
  )}
  {clinic.services && clinic.services.length > 0 && (
    <div class="mt-3 flex flex-wrap gap-1.5">
      {clinic.services.slice(0, 4).map((s) => (
        <span class="inline-flex items-center rounded-full bg-brand-50 px-2.5 py-0.5 text-xs font-medium text-brand-700 ring-1 ring-inset ring-brand-200">
          {s}
        </span>
      ))}
    </div>
  )}
  <div class="mt-4 flex items-center gap-4 text-xs text-ink-500">
    {clinic.phone && (
      <span class="inline-flex items-center gap-1">
        <Icon name="phone" size={12} class="text-ink-400" />
        {clinic.phone}
      </span>
    )}
    {clinic.website && (
      <span class="inline-flex items-center gap-1 truncate max-w-[180px]">
        <Icon name="globe" size={12} class="text-ink-400 shrink-0" />
        <span class="truncate">{clinic.website.replace(/^https?:\/\//, '').replace(/\/$/, '')}</span>
      </span>
    )}
  </div>
</a>
