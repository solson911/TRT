---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
  jsonLd?: unknown;
}

const {
  title,
  description = 'Find testosterone replacement therapy clinics, online TRT providers, ratings, services, and contact information across the United States.',
  canonical,
  noindex = false,
  jsonLd,
} = Astro.props;
const canonicalHref = canonical ?? new URL(Astro.url.pathname, Astro.site ?? 'https://trtindex.com').toString();
const navLinks = [
  { href: '/clinics/', label: 'Find a clinic' },
  { href: '/guides/', label: 'Guides' },
  { href: '/news/', label: 'News' },
  { href: '/telehealth/', label: 'Telehealth' },
  { href: '/about/', label: 'About' },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonicalHref} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={new URL('/og-image.png', Astro.site ?? 'https://trtindex.com').toString()} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="1200" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:image" content={new URL('/og-image.png', Astro.site ?? 'https://trtindex.com').toString()} />

    {jsonLd && (Array.isArray(jsonLd) ? jsonLd : [jsonLd]).map((doc) => (
      <script type="application/ld+json" set:html={JSON.stringify(doc)} />
    ))}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap" />
  </head>
  <body class="bg-ink-50 text-ink-900">
    <header class="sticky top-0 z-40 border-b border-ink-100 bg-white/85 backdrop-blur">
      <div class="container-prose flex h-20 md:h-28 items-center justify-between">
        <a href="/" class="flex items-center" aria-label="TRT Index - home">
          <img src="/logo.png" alt="TRT Index" width="940" height="225" class="h-9 md:h-11 w-auto" />
        </a>
        <nav class="hidden md:flex items-center gap-6 text-sm font-medium text-ink-600">
          {navLinks.map((link) => (
            <a href={link.href} class="hover:text-ink-900">{link.label}</a>
          ))}
          <a href="/for-clinics/" class="inline-flex items-center rounded-lg bg-ink-900 px-3 py-1.5 text-white hover:bg-ink-700">For clinics</a>
        </nav>
        <details class="group relative md:hidden">
          <summary class="flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-lg border border-ink-200 bg-white text-ink-800 transition hover:border-ink-300" aria-label="Open navigation">
            <span class="sr-only">Menu</span>
            <svg class="h-5 w-5 group-open:hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 6h16" />
              <path d="M4 12h16" />
              <path d="M4 18h16" />
            </svg>
            <svg class="hidden h-5 w-5 group-open:block" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 6 6 18" />
              <path d="m6 6 12 12" />
            </svg>
          </summary>
          <nav class="absolute right-0 top-12 z-50 w-64 overflow-hidden rounded-xl bg-white py-2 text-sm font-medium text-ink-700 shadow-xl ring-1 ring-ink-100">
            {navLinks.map((link) => (
              <a href={link.href} class="block px-4 py-3 hover:bg-brand-50 hover:text-ink-900">{link.label}</a>
            ))}
            <div class="my-1 border-t border-ink-100"></div>
            <a href="/for-clinics/" class="block px-4 py-3 font-semibold text-brand-700 hover:bg-brand-50">For clinics</a>
          </nav>
        </details>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-24 border-t border-ink-100 bg-white">
      <div class="container-prose py-12 grid grid-cols-1 md:grid-cols-4 gap-8 text-sm">
        <div class="md:col-span-1">
          <a href="/" class="inline-flex items-center" aria-label="TRT Index - home">
            <img src="/logo.png" alt="TRT Index" width="940" height="225" class="h-8 w-auto" />
          </a>
          <p class="mt-3 text-ink-500">A directory of testosterone replacement therapy clinics across the United States.</p>
        </div>
        <div>
          <div class="font-semibold text-ink-900 mb-3">Directory</div>
          <ul class="space-y-2 text-ink-500">
            <li><a href="/clinics/" class="hover:text-ink-900">Browse by state</a></li>
            <li><a href="/telehealth/" class="hover:text-ink-900">Telehealth providers</a></li>
          </ul>
        </div>
        <div>
          <div class="font-semibold text-ink-900 mb-3">Guides</div>
          <ul class="space-y-2 text-ink-500">
            <li><a href="/guides/what-is-trt/" class="hover:text-ink-900">What is TRT?</a></li>
            <li><a href="/guides/cost-guide/" class="hover:text-ink-900">TRT cost guide</a></li>
            <li><a href="/guides/telehealth-vs-in-person/" class="hover:text-ink-900">Telehealth vs in-person</a></li>
            <li><a href="/guides/glossary/" class="hover:text-ink-900">Glossary</a></li>
          </ul>
        </div>
        <div>
          <div class="font-semibold text-ink-900 mb-3">Site</div>
          <ul class="space-y-2 text-ink-500">
            <li><a href="/about/" class="hover:text-ink-900">About</a></li>
            <li><a href="/news/" class="hover:text-ink-900">News & research</a></li>
            <li><a href="/guides/" class="hover:text-ink-900">All guides</a></li>
            <li><a href="/for-clinics/" class="hover:text-ink-900">For clinics</a></li>
            <li><a href="/terms/" class="hover:text-ink-900">Terms of service</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-ink-100">
        <div class="container-prose py-5 text-xs text-ink-500 flex flex-col md:flex-row md:items-center md:justify-between gap-3">
          <div>© {new Date().getFullYear()} TRT Index. Informational directory; not medical advice.</div>
          <div>Always consult a licensed healthcare provider before starting testosterone therapy.</div>
        </div>
      </div>
    </footer>
  </body>
</html>
