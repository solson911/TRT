---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
  jsonLd?: unknown;
}

const { title, description = 'Find TRT clinics across the United States.', canonical, noindex = false, jsonLd } = Astro.props;
const canonicalHref = canonical ?? new URL(Astro.url.pathname, Astro.site ?? 'https://trtindex.com').toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonicalHref} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={new URL('/og-image.png', Astro.site ?? 'https://trtindex.com').toString()} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="1200" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:image" content={new URL('/og-image.png', Astro.site ?? 'https://trtindex.com').toString()} />

    {jsonLd && (Array.isArray(jsonLd) ? jsonLd : [jsonLd]).map((doc) => (
      <script type="application/ld+json" set:html={JSON.stringify(doc)} />
    ))}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap" />
  </head>
  <body class="bg-ink-50 text-ink-900">
    <header class="sticky top-0 z-40 border-b border-ink-100 bg-white/85 backdrop-blur">
      <div class="container-prose flex h-20 md:h-28 items-center justify-between">
        <a href="/" class="flex items-center" aria-label="TRT Index - home">
          <img src="/logo.png" alt="TRT Index" width="1248" height="304" class="h-9 md:h-11 w-auto" />
        </a>
        <nav class="hidden md:flex items-center gap-6 text-sm font-medium text-ink-600">
          <a href="/clinics/" class="hover:text-ink-900">Find a clinic</a>
          <a href="/guides/" class="hover:text-ink-900">Guides</a>
          <a href="/telehealth/" class="hover:text-ink-900">Telehealth</a>
          <a href="/about/" class="hover:text-ink-900">About</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-24 border-t border-ink-100 bg-white">
      <div class="container-prose py-12 grid grid-cols-1 md:grid-cols-4 gap-8 text-sm">
        <div class="md:col-span-1">
          <a href="/" class="inline-flex items-center" aria-label="TRT Index - home">
            <img src="/logo.png" alt="TRT Index" width="1248" height="304" class="h-8 w-auto" />
          </a>
          <p class="mt-3 text-ink-500">A directory of testosterone replacement therapy clinics across the United States.</p>
        </div>
        <div>
          <div class="font-semibold text-ink-900 mb-3">Directory</div>
          <ul class="space-y-2 text-ink-500">
            <li><a href="/clinics/" class="hover:text-ink-900">Browse by state</a></li>
            <li><a href="/telehealth/" class="hover:text-ink-900">Telehealth providers</a></li>
          </ul>
        </div>
        <div>
          <div class="font-semibold text-ink-900 mb-3">Guides</div>
          <ul class="space-y-2 text-ink-500">
            <li><a href="/guides/what-is-trt/" class="hover:text-ink-900">What is TRT?</a></li>
            <li><a href="/guides/cost-guide/" class="hover:text-ink-900">TRT cost guide</a></li>
            <li><a href="/guides/telehealth-vs-in-person/" class="hover:text-ink-900">Telehealth vs in-person</a></li>
            <li><a href="/guides/glossary/" class="hover:text-ink-900">Glossary</a></li>
          </ul>
        </div>
        <div>
          <div class="font-semibold text-ink-900 mb-3">Site</div>
          <ul class="space-y-2 text-ink-500">
            <li><a href="/about/" class="hover:text-ink-900">About</a></li>
            <li><a href="/guides/" class="hover:text-ink-900">All guides</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-ink-100">
        <div class="container-prose py-5 text-xs text-ink-500 flex flex-col md:flex-row md:items-center md:justify-between gap-3">
          <div>© {new Date().getFullYear()} TRT Index. Informational directory - not medical advice.</div>
          <div>Always consult a licensed healthcare provider before starting testosterone therapy.</div>
        </div>
      </div>
    </footer>
  </body>
</html>
