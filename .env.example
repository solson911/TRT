# Copy to `.env` and fill in values. `.env` is gitignored; this template is safe to commit.

# Yelp Fusion API key — scraper credential (optional; currently unused).
# Sign up: https://www.yelp.com/developers
YELP_API_KEY=

# GitHub fine-grained PAT scoped to the trt-clinics repo.
# Create: GitHub → Settings → Developer settings → Personal access tokens → Fine-grained.
# Scopes: Contents read/write, Pull requests read/write (Metadata read is auto-included).
# Used by automation scripts for unattended commits and PR creation.
GITHUB_TOKEN=
